# Backend — copy to .env at repo root and/or apps/api/.env (both are loaded; apps/api/.env wins on duplicate keys)
PORT=4000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# نموذج أقوى لشات المتجر عند اشتراك Stripe نشط (active / trialing). الافتراضي: OPENAI_MODEL
# OPENAI_MODEL_PAID=gpt-4o
# نموذج اقتصادي لباقي حالات الاشتراك. الافتراضي: OPENAI_MODEL
# OPENAI_MODEL_ECONOMY=gpt-4o-mini
# اختياري: حرارة الرد (0–2). أعلى = أكثر تنوعًا ودفئًا؛ الافتراضي في الكود 0.65
# OPENAI_TEMPERATURE=0.65
AUTH_SECRET=change-this-dev-secret
# مفتاح واجهة إدارة المنصة (رأس X-Admin-Key). إن لم يُضبط، مسارات /api/admin/* تُعطل.
ADMIN_API_KEY=
# Optional: SQLite file path (Docker Compose sets SQLITE_PATH=/data/dm-commerce.sqlite)
# SQLITE_PATH=

# Where the owner returns after Stripe Checkout / Billing Portal (dev: Vite port; Docker web: http://localhost:8080)
FRONTEND_URL=http://localhost:5173

# Meta Instagram — webhook subscription handshake (GET) and later messaging (POST)
# META_APP_ID=
# META_VERIFY_TOKEN=your-random-verify-string
# META_APP_SECRET=
# META_GRAPH_API_VERSION=v21.0
#
# Facebook Login / Instagram connect (owner dashboard button):
# 1) Meta App → Settings → Basic → App domains: shopiq.me  (no https://)
# 2) Meta App → Facebook Login → Settings → Valid OAuth Redirect URIs:
#    https://api.shopiq.me/api/auth/facebook/callback
# 3) Meta App → Settings → Basic → Website → Site URL: https://www.shopiq.me
# 4) Add products: Messenger + Instagram Messaging; request instagram_manage_messages
# 5) Server env must match exactly:
# META_OAUTH_REDIRECT_URI=https://api.shopiq.me/api/auth/facebook/callback
# API_PUBLIC_URL=https://api.shopiq.me
# FRONTEND_URL=https://www.shopiq.me

# Encrypt channel OAuth tokens at rest (channel_connections.access_token_enc).
# Use 64-char hex (32 bytes), or base64 of 32 bytes, or a long passphrase (scrypt-derived).
# Generate hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CHANNEL_TOKEN_ENCRYPTION_KEY=

# Stripe subscription (owner dashboard). Billing is enforced when STRIPE_SECRET_KEY is set AND at least one price ID is set below.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Legacy single price (checkout plan "starter" if STRIPE_PRICE_STARTER is unset)
STRIPE_PRICE_ID=
# Recommended: three Stripe Price IDs for Starter ($19) / Growth ($49) / Pro ($99) monthly subscriptions
# STRIPE_PRICE_STARTER=price_xxx
# STRIPE_PRICE_GROWTH=price_yyy
# STRIPE_PRICE_PRO=price_zzz

# Frontend — أصل الـ API فقط (مثال: http://31.220.73.14:4000). لا تضف /api في النهاية؛ الكود يضيف مسارات مثل /api/... و /uploads/...
VITE_API_URL=http://localhost:4000
