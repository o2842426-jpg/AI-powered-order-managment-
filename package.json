{
  "name": "dm-commerce",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "preview:web": "npm --workspace apps/web run preview",
    "deploy:web": "npm run build:web && bash scripts/deploy-web-static.sh",
    "deploy:web:static": "bash scripts/deploy-web-static.sh",
    "deploy:api": "pm2 restart shopiq-api --update-env",
    "deploy": "npm run build:web && bash scripts/deploy-web-static.sh && pm2 restart shopiq-api --update-env",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  }
}
